import ctypes
import ctypes.util
import platform
import sys


def _open_window_macos(title: str, width: int, height: int) -> None:
    objc = ctypes.CDLL(ctypes.util.find_library("objc"))
    objc.objc_getClass.restype = ctypes.c_void_p
    objc.objc_getClass.argtypes = [ctypes.c_char_p]

    ctypes.CDLL(ctypes.util.find_library("Cocoa"))

    objc.sel_registerName.restype = ctypes.c_void_p
    objc.sel_registerName.argtypes = [ctypes.c_char_p]

    objc.objc_msgSend.restype = ctypes.c_void_p
    objc.objc_msgSend.argtypes = [ctypes.c_void_p, ctypes.c_void_p]

    window_class = objc.objc_getClass(b"NSWindow")
    alloc_sel = objc.sel_registerName(b"alloc")
    window = objc.objc_msgSend(window_class, alloc_sel)

    class NSRect(ctypes.Structure):
        _fields_ = [
            ("x", ctypes.c_double),
            ("y", ctypes.c_double),
            ("width", ctypes.c_double),
            ("height", ctypes.c_double),
        ]
    
    init_sel = objc.sel_registerName(b"initWithContentRect:styleMask:backing:defer:")
    objc.objc_msgSend.argtypes = [ctypes.c_void_p, ctypes.c_void_p, NSRect,
                                  ctypes.c_ulong, ctypes.c_ulong, ctypes.c_bool]

    frame = NSRect(100, 100, width, height)
    style_mask = 1 | 2 | 0 | 8  # titled | closable | resizable | miniaturizable
    backing = 2  # NSBackingStoreBuffered
    defer = False

    window = objc.objc_msgSend(window, init_sel, frame, style_mask, backing, defer)
    objc.objc_msgSend.argtypes = [ctypes.c_void_p, ctypes.c_void_p]

    app_class = objc.objc_getClass(b"NSApplication")
    shared_app_sel = objc.sel_registerName(b"sharedApplication")
    app = objc.objc_msgSend(app_class, shared_app_sel)
    
    objc.objc_msgSend.argtypes = [ctypes.c_void_p, ctypes.c_void_p, ctypes.c_void_p]
    make_key_sel = objc.sel_registerName(b"makeKeyAndOrderFront:")
    objc.objc_msgSend(window, make_key_sel, None)

    objc.objc_msgSend.argtypes = [ctypes.c_void_p, ctypes.c_void_p, ctypes.c_bool]
    activate_sel = objc.sel_registerName(b"activateIgnoringOtherApps:")
    objc.objc_msgSend(app, activate_sel, True)

    objc.objc_msgSend.argtypes = [ctypes.c_void_p, ctypes.c_void_p]
    display_sel = objc.sel_registerName(b"display")
    objc.objc_msgSend(window, display_sel)

    finish_launching_sel = objc.sel_registerName(b"finishLaunching")
    objc.objc_msgSend(app, finish_launching_sel)

    import time
    time.sleep(5)


# ---------------------------------------------------------------------------
# Point d'entrée commun
# ---------------------------------------------------------------------------
def open_window(title: str = "Mon Moteur", width: int = 800, height: int = 600) -> None:
    system = platform.system()
    if system == "Windows":
        pass
    elif system == "Linux":
        pass
    elif system == "Darwin":
        _open_window_macos(title, width, height)
    else:
        raise RuntimeError(f"OS non supporté : {system}")


if __name__ == "__main__":
    try:
        open_window("Sharpy", 800, 600)
    except Exception as e:
        print(f"Erreur : {e}", file=sys.stderr)
        sys.exit(1)